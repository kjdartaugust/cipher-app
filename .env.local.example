# Supabase — fill these in from your Supabase project settings (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Leave the two values above as the example placeholders to run Cipher in
# fully-local DEMO MODE (no Supabase required, seeded sample data, mock realtime).

# --- Optional: Web Push (background notifications) ---
# Generate a pair with:  npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Server-only key used by /api/notify to read recipients' push subscriptions.
# NEVER prefix with NEXT_PUBLIC — it must stay on the server.
SUPABASE_SERVICE_ROLE_KEY=
